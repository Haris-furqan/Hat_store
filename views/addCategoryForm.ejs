<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Item</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #0e0e10;
            --surface: #1a1a1e;
            --border: #2e2e34;
            --accent: #e8ff47;
            --text: #f0f0f0;
            --muted: #888;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: grid;
            place-items: center;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 2.5rem;
            width: 100%;
            max-width: 420px;
        }

        h1 {
            font-family: 'Syne', sans-serif;
            font-size: 1.8rem;
            letter-spacing: -0.03em;
            margin-bottom: 0.3rem;
        }

        .subtitle {
            color: var(--muted);
            font-size: 0.9rem;
            margin-bottom: 2rem;
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 0.45rem;
            margin-bottom: 1.25rem;
        }

        label {
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        input, select {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            padding: 0.75rem 1rem;
            outline: none;
            transition: border-color 0.2s;
            width: 100%;
        }

        input::placeholder { color: #555; }

        input:focus, select:focus {
            border-color: var(--accent);
        }

        select option {
            background: var(--surface);
        }

        .btn-primary {
            width: 100%;
            margin-top: 0.75rem;
            padding: 0.9rem;
            background: var(--accent);
            color: #0e0e10;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            background: #f5ff7a;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(232, 255, 71, 0.25);
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 1.25rem;
            color: var(--muted);
            font-size: 0.875rem;
            text-decoration: none;
            transition: color 0.2s;
        }

        .back-link:hover { color: var(--text); }
    </style>
</head>
<body>
    <div class="card">
        <h1>Add Hat</h1>
        <p class="subtitle">Fill in the details below</p>

        <form action="/category/add" method="post">
            <div class="field">
                <label for="categoryName">Hat Name</label>
                <input type="text" id="categoryName" name="categoryName" placeholder="e.g CowBoy Hat">
            </div>

            <button type="submit" class="btn-primary">Add Category</button>
        </form>

        <a href="/" class="back-link">← Back to Home</a>
    </div>
</body>
</html>