<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #0e0e10;
            --surface: #1a1a1e;
            --border: #2e2e34;
            --accent: #e8ff47;
            --text: #f0f0f0;
            --muted: #888;
            --error: #ff4d4d;
            --error-bg: #1f1314;
            --error-border: #3d1f1f;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: grid;
            place-items: center;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 2.5rem;
            width: 100%;
            max-width: 420px;
        }

        h1 {
            font-family: 'Syne', sans-serif;
            font-size: 1.8rem;
            letter-spacing: -0.03em;
            margin-bottom: 0.3rem;
        }

        .subtitle {
            color: var(--muted);
            font-size: 0.9rem;
            margin-bottom: 2rem;
        }

        .error-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            list-style: none;
        }

        .error-item {
            background: var(--error-bg);
            border: 1px solid var(--error-border);
            border-left: 3px solid var(--error);
            border-radius: 8px;
            padding: 0.85rem 1rem;
            font-size: 0.9rem;
            color: #ffaaaa;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .error-icon {
            color: var(--error);
            font-size: 1rem;
            flex-shrink: 0;
        }

        .btn-primary {
            display: block;
            width: 100%;
            margin-top: 2rem;
            padding: 0.9rem;
            background: var(--accent);
            color: #0e0e10;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            background: #f5ff7a;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(232, 255, 71, 0.25);
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>Oops!</h1>
        <p class="subtitle"><%= errors.length %> error<%= errors.length !== 1 ? 's' : '' %> found</p>
        <%console.log(errors) %>
        <ul class="error-list">
            <% errors.forEach(function(error) { %>
                <li class="error-item">
                    <span class="error-icon">✕</span>
                    <%= error.msg %>
                </li>
            <% }) %>
        </ul>

        <a href="javascript:history.back()" class="btn-primary">← Go Back</a>
    </div>
</body>
</html>