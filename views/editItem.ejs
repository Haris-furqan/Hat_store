<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="/dist/output.css" rel="stylesheet" />
    <title>Document</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400..800&display=swap" rel="stylesheet">
</head>
<body>
    <style>
        body
        {
            background-color: #0E0E10;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .container
        {
            background-color:#1A1A1E;
            margin: 100px;
            border:1px solid gray ;
            border-radius: 5px;
            height: 70vh;
            width: 30vw;
            padding: 40px;
            display: flex;
            justify-content: center;
        }
        label
        {
            color: gray;
           
        }
        input
        {
            background-color: rgb(49, 49, 49);
            padding: 5px;
            border: 1px solid rgb(76, 76, 76);
            border-radius: 7px;
            color: white;
            margin: 20px 0px;
            height: 30px;
            width: 110%;
        }
        button
        {
            background-color: #d9e741;
            height: 40px;
            width: 50%;
            
            border: none;
            border-radius: 5px;
        
            font-weight: bold;
            transition: all ease-in-out 200ms;
        }
        button:hover
        {
            transform: translateY(-5px);
            background-color: #e5ef70;
            box-shadow: #ced678 2px 0px 10px 2px;
        }
        .btn-container
        {
            display: flex;
            justify-content: center;
        }
    </style>
    <div class="container" >
    <form action="/items/<%=item.item_id%>/update" method="post">

            <h1>
                Update Items
            </h1>
            <label for="itemName">New Name 
               <br> <input type="text" name="itemName" id="itemName" value="<%=item.item_name%>">
        </label>
        <br>
        <label for="Quantity">
            New Quantity
            <br><input type="number" min="0" name="Quantity" id="Quantity" value="<%=item.quantity%>">
        </label>
        <br>
        <div class="btn-container">

            <button type="submit">Update</button>
        </div>
    </form>
</div>
</body>
</html>